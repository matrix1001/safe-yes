{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|WebSearch|WebFetch|Write|Edit|Read|Glob|Grep|TodoWrite|Task|Skill|mcp__.+",
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/scripts/guard.py",
            "timeout": 15000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/scripts/guard.py",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
